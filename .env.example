# --- Database ---------------------------------------------------------------
# Matches the local Postgres in docker-compose.yml.
# For a cloud DB (Neon, Supabase, RDS) paste its connection string instead.
DATABASE_URL="postgresql://washai:washai@localhost:5432/washai?schema=public"

# --- Claude API -------------------------------------------------------------
# Get a key from https://console.anthropic.com/ (or run `ant auth login`).
ANTHROPIC_API_KEY=""

# Optional: override the model. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL="claude-opus-4-8"
